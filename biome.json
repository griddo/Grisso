{
	"$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
	"formatter": {
		"indentStyle": "tab"
	},
	"linter": {
		"rules": {
			"recommended": true,
			"suspicious": {
				"noUnknownAtRules": {
					"level": "error",
					"options": {
						"ignore": ["grisso"]
					}
				}
			}
		}
	},
	"files": {
		"includes": [
			"**",
			"!dist",
			"!lib",
			"!node_modules",
			"!.claude",
			"!playground/grisso.css"
		]
	}
}
